# =============================================================================
# TitanTech - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=25011

# Set to true to trust proxy headers (required if behind nginx/load balancer)
TRUST_PROXY=true

# -----------------------------------------------------------------------------
# Session Security
# -----------------------------------------------------------------------------
# Generate a strong session secret with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# This MUST be at least 32 characters and cryptographically random
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARACTERS_LONG

# Session cookie name (optional, defaults to titantech.sid)
SESSION_NAME=titantech.sid

# Session duration in milliseconds (7 days = 604800000)
SESSION_MAX_AGE=604800000

# -----------------------------------------------------------------------------
# Discord Integration
# -----------------------------------------------------------------------------
# Discord webhook URL for notifications (INI generator notifications)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Discord OAuth (if using Discord login)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_CALLBACK_URL=https://yourdomain.com/auth/discord/callback

# Discord bot public key for webhook signature verification (Ed25519)
DISCORD_PUBLIC_KEY=your_discord_public_key_here

# -----------------------------------------------------------------------------
# External API Configuration
# -----------------------------------------------------------------------------
# GSH Servers API
GSH_API_HOST=pot-api.gsh-servers.com
GSH_API_TOKEN=your_gsh_api_token_here

# Internal Mods API (for mod manager)
INTERNAL_API_HOST=848da576-521b-4606-a37f-cd7512c5a67e
API_PORT=25010

# Dev/Alternative API host (used with --dev flag)
DEV_API_HOST=172.93.102.240

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS
# Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=https://titantech.party,https://www.titantech.party

# Set to true to enable CORS in development (allows localhost origins)
CORS_DEV_MODE=false

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Rate limit window in minutes
RATE_LIMIT_WINDOW_MS=15

# Max requests per window for standard endpoints
RATE_LIMIT_MAX=100

# Max login attempts per window
AUTH_RATE_LIMIT_MAX=5

# Max file uploads per hour
UPLOAD_RATE_LIMIT_MAX=10

# -----------------------------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------------------------
# Maximum file size for uploads in bytes (10MB = 10485760)
MAX_FILE_SIZE=10485760

# Upload directory (relative to project root)
UPLOAD_DIR=./uploads

# Enable file content validation (recommended)
VALIDATE_FILE_CONTENT=true

# -----------------------------------------------------------------------------
# Database Configuration (if/when you add a database)
# -----------------------------------------------------------------------------
# DATABASE_URL=mongodb://localhost:27017/titantech
# DATABASE_NAME=titantech

# -----------------------------------------------------------------------------
# Email Configuration (if/when you add email)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_email_password
# EMAIL_FROM=noreply@titantech.party

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Log level: error, warn, info, debug
LOG_LEVEL=info

# Enable audit logging for security events
AUDIT_LOG_ENABLED=true

# -----------------------------------------------------------------------------
# Security Features
# -----------------------------------------------------------------------------
# Enable HSTS in production (forces HTTPS)
ENABLE_HSTS=true

# Enable CSP (Content Security Policy)
ENABLE_CSP=true

# Enable strict CORS (recommended for production)
STRICT_CORS=true

# Enable webhook signature verification
VERIFY_WEBHOOKS=true

# -----------------------------------------------------------------------------
# Admin Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of admin user IDs (Discord IDs)
ADMIN_USER_IDS=

# Default admin username (for file-based auth - remove when using real DB)
# IMPORTANT: Change these immediately or remove once you have proper user management
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_IMMEDIATELY

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable showcase feature
ENABLE_SHOWCASE=true

# Enable commission requests
ENABLE_COMMISSIONS=true

# Enable community servers
ENABLE_COMMUNITY_SERVERS=true

# -----------------------------------------------------------------------------
# Cache Configuration
# -----------------------------------------------------------------------------
# Cache duration for servers in milliseconds (2 minutes = 120000)
SERVERS_CACHE_DURATION=120000

# Cache duration for mods in milliseconds (10 minutes = 600000)
MODS_CACHE_DURATION=600000

# -----------------------------------------------------------------------------
# Development/Debug Settings
# -----------------------------------------------------------------------------
# Enable detailed error messages (disable in production!)
DEBUG_MODE=false

# Enable verbose logging
VERBOSE_LOGS=false

# Skip authentication (NEVER enable in production!)
SKIP_AUTH=false
